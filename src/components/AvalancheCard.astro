---
// Avalanche Canada bulletin card for the Sea-to-Sky region.
// Uses the public API; degrades gracefully to a link if it fails.
---

<section class="surface p-5 sm:p-6" id="avalanche-card">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <div class="text-xs uppercase tracking-widest muted font-display">Avalanche Canada</div>
      <h2 class="font-display text-2xl font-semibold">Sea-to-Sky Bulletin</h2>
    </div>
    <a
      class="btn !text-xs !py-1.5 !px-3"
      href="https://avalanche.ca/forecasts/sea-to-sky"
      target="_blank"
      rel="noopener"
    >
      Full forecast ↗
    </a>
  </div>

  <!-- Danger ratings by elevation -->
  <div class="mt-4 grid grid-cols-3 gap-3" id="av-ratings-grid">
    <div class="rounded-xl p-3 text-center skeleton" id="av-alp" style="min-height:4.5rem;">
      <div class="text-[11px] uppercase tracking-wider font-display opacity-70">Alpine</div>
      <div class="font-display text-lg font-semibold mt-0.5" data-level>—</div>
    </div>
    <div class="rounded-xl p-3 text-center skeleton" id="av-tln" style="min-height:4.5rem;">
      <div class="text-[11px] uppercase tracking-wider font-display opacity-70">Treeline</div>
      <div class="font-display text-lg font-semibold mt-0.5" data-level>—</div>
    </div>
    <div class="rounded-xl p-3 text-center skeleton" id="av-btl" style="min-height:4.5rem;">
      <div class="text-[11px] uppercase tracking-wider font-display opacity-70">Below</div>
      <div class="font-display text-lg font-semibold mt-0.5" data-level>—</div>
    </div>
  </div>

  <!-- Headline + summary -->
  <div class="mt-4 space-y-2">
    <div id="av-date" class="text-xs muted skeleton w-36">&nbsp;</div>
    <p id="av-headline" class="text-sm font-medium leading-relaxed">
      <span class="skeleton inline-block w-full h-4">&nbsp;</span>
    </p>
    <p id="av-summary" class="text-sm muted leading-relaxed">
      <span class="skeleton inline-block w-full h-4">&nbsp;</span>
    </p>
  </div>
</section>

<script>
  type ApiRating = {
    date?: { value?: string; display?: string };
    ratings?: {
      alp?: { display?: string; rating?: { value?: string; display?: string } };
      tln?: { display?: string; rating?: { value?: string; display?: string } };
      btl?: { display?: string; rating?: { value?: string; display?: string } };
    };
  };
  type ApiPayload = {
    dangerRatings?: Array<ApiRating>;
    report?: {
      highlights?: string;
      summaries?: Array<{ type: { value?: string; display?: string }; content: string }>;
      dateIssued?: string;
    };
  };

  const dangerColor: Record<string, { bg: string; text: string }> = {
    low: { bg: "var(--color-pine-500)", text: "#04131a" },
    moderate: { bg: "#f2c94c", text: "#04131a" },
    considerable: { bg: "var(--color-sunset-500)", text: "#fff" },
    high: { bg: "#e24040", text: "#fff" },
    extreme: { bg: "#111", text: "#fff" },
  };

  function stripHtml(html: string) {
    const doc = new DOMParser().parseFromString(html, "text/html");
    return (doc.body.textContent ?? "").trim();
  }

  function dangerLabel(value: string | undefined): string {
    if (!value) return "—";
    // value is like "moderate" or display is like "2 - Moderate"
    return value.charAt(0).toUpperCase() + value.slice(1);
  }

  function setRatingBand(elId: string, rating?: { value?: string; display?: string }) {
    const el = document.getElementById(elId);
    if (!el) return;
    const key = (rating?.value ?? "").toLowerCase();
    const label = dangerLabel(key);
    const colors = dangerColor[key] ?? { bg: "var(--bg-elev-2)", text: "var(--fg)" };

    el.style.background = colors.bg;
    el.style.color = colors.text;
    el.classList.remove("skeleton");

    const levelEl = el.querySelector("[data-level]");
    if (levelEl) levelEl.textContent = label;
  }

  function setSkeleton(id: string, text: string) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = text;
    el.classList.remove("skeleton");
  }

  function renderError() {
    ["av-alp", "av-tln", "av-btl"].forEach((id) => {
      const el = document.getElementById(id);
      if (el) {
        el.classList.remove("skeleton");
        el.style.background = "var(--bg-elev-2)";
      }
    });
    setSkeleton("av-date", "");
    const head = document.getElementById("av-headline");
    if (head) {
      head.innerHTML = "";
      head.textContent =
        "We couldn't load the live bulletin. Check Avalanche Canada directly before heading out.";
    }
    const sum = document.getElementById("av-summary");
    if (sum) sum.innerHTML = "";
  }

  async function load() {
    const url =
      "https://api.avalanche.ca/forecasts/en/products/348f8674-63fc-4863-98c3-4caa1c25656d_7b481d084742506edf5d3e899c3e75fb0e0262cdc3a243efe86d6b1ba8eeeba8";
    const res = await fetch(url);
    if (!res.ok) throw new Error(`avalanche api ${res.status}`);
    const data = (await res.json()) as ApiPayload;

    // Set danger ratings for each elevation band (today = first entry)
    const today = data.dangerRatings?.[0]?.ratings;
    setRatingBand("av-alp", today?.alp?.rating);
    setRatingBand("av-tln", today?.tln?.rating);
    setRatingBand("av-btl", today?.btl?.rating);

    // Date
    const dateIssued = data.report?.dateIssued
      ? new Date(data.report.dateIssued).toLocaleString([], {
          month: "short",
          day: "numeric",
          hour: "numeric",
          minute: "2-digit",
        })
      : "";
    setSkeleton("av-date", dateIssued ? `Issued ${dateIssued}` : "");

    // Highlights
    const headline = data.report?.highlights ?? "";
    const head = document.getElementById("av-headline");
    if (head) {
      head.innerHTML = "";
      head.textContent = headline ? stripHtml(headline) : "";
    }

    // Avalanche summary
    const summary =
      data.report?.summaries?.find((s) => /avalanche|summary/i.test(s.type?.value ?? ""))?.content ?? "";
    const sum = document.getElementById("av-summary");
    if (sum) {
      sum.innerHTML = "";
      sum.textContent = summary ? stripHtml(summary) : "";
    }
  }

  load().catch((err) => {
    console.warn("[avalanche]", err);
    renderError();
  });
</script>
