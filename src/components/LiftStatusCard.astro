---
// Whistler Blackcomb does not publish a stable public JSON for lift status, so
// this card links to the official dashboard instead of faking data.
const links = [
  {
    href: "https://www.whistlerblackcomb.com/the-mountain/mountain-conditions/terrain-and-lift-status.aspx",
    label: "Terrain & Lift Status",
    desc: "Live open/closed lifts and open trails",
  },
  {
    href: "https://www.whistlerblackcomb.com/the-mountain/mountain-conditions/snow-and-weather-report.aspx",
    label: "Snow & Weather Report",
    desc: "Daily snow totals and mountain weather",
  },
  {
    href: "https://secure.whistlerblackcomb.com/TomPDF/Default.aspx?Season=1&Type=bg",
    label: "Grooming Report (PDF)",
    desc: "Today's groomed runs",
  },
];
---

<section class="surface p-5 sm:p-6">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <div class="text-xs uppercase tracking-widest muted font-display">Whistler Blackcomb</div>
      <h2 class="font-display text-2xl font-semibold">Mountain Reports</h2>
    </div>
    <span class="chip">
      <span class="h-2 w-2 rounded-full" style="background: var(--color-pine-500);"></span>
      Official
    </span>
  </div>
  <ul class="mt-4 divide-y" style="border-color: var(--border);">
    {
      links.map((l) => (
        <li>
          <a
            href={l.href}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-between gap-4 py-3 group"
          >
            <div>
              <div class="font-medium group-hover:text-[var(--accent-strong)] transition-colors">
                {l.label}
              </div>
              <div class="text-xs muted">{l.desc}</div>
            </div>
            <svg class="opacity-50 group-hover:opacity-100 transition-opacity" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  ul li + li { border-top-width: 1px; }
</style>
