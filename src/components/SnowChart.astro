---
// 7-day snow/temperature chart. Renders client-side from Open-Meteo historical forecast.
---

<section class="surface p-5 sm:p-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <div class="text-xs uppercase tracking-widest muted font-display">Last 7 Days</div>
      <h2 class="font-display text-2xl font-semibold">Snow &amp; Temp</h2>
    </div>
    <div class="flex items-center gap-4 text-xs">
      <span class="flex items-center gap-1.5">
        <span class="h-2 w-4 rounded-sm" style="background: var(--accent);"></span>
        Snowfall (in)
      </span>
      <span class="flex items-center gap-1.5">
        <span class="h-1 w-4 rounded-sm" style="background: var(--color-sunset-400);"></span>
        High/Low (°C)
      </span>
    </div>
  </div>

  <div class="mt-4 relative" style="height: 220px;">
    <svg
      id="snow-chart"
      viewBox="0 0 700 220"
      preserveAspectRatio="none"
      class="w-full h-full"
      role="img"
      aria-label="7-day snow and temperature chart"
    >
    </svg>
    <div
      id="snow-chart-empty"
      class="absolute inset-0 grid place-items-center muted text-sm hidden"
    >
      No data available
    </div>
  </div>
  <div id="snow-chart-labels" class="mt-2 grid grid-cols-7 text-xs muted text-center"></div>
</section>

<script>
  type Data = {
    daily: {
      time: string[];
      snowfall_sum: number[];
      temperature_2m_max: number[];
      temperature_2m_min: number[];
    };
  };

  const W = 700;
  const H = 220;
  const PAD_X = 28;
  const PAD_Y = 24;

  function dayShort(iso: string) {
    return new Date(iso + "T12:00:00").toLocaleDateString([], { weekday: "short" });
  }

  function renderChart(d: Data) {
    const svg = document.getElementById("snow-chart") as unknown as SVGSVGElement | null;
    const labels = document.getElementById("snow-chart-labels");
    const empty = document.getElementById("snow-chart-empty");
    if (!svg || !labels) return;
    const { time, snowfall_sum, temperature_2m_max, temperature_2m_min } = d.daily;
    if (!time?.length) {
      empty?.classList.remove("hidden");
      return;
    }
    const n = time.length;
    const maxSnow = Math.max(1, ...snowfall_sum);
    const tAll = [...temperature_2m_max, ...temperature_2m_min];
    const tMin = Math.min(...tAll);
    const tMax = Math.max(...tAll);
    const tPad = Math.max(1, (tMax - tMin) * 0.15);
    const tLo = tMin - tPad;
    const tHi = tMax + tPad;

    const innerW = W - PAD_X * 2;
    const innerH = H - PAD_Y * 2;
    const step = innerW / n;
    const barW = step * 0.55;

    const xCenter = (i: number) => PAD_X + step * i + step / 2;
    const yTemp = (t: number) =>
      PAD_Y + innerH - ((t - tLo) / (tHi - tLo)) * innerH;
    const ySnow = (s: number) =>
      PAD_Y + innerH - (s / maxSnow) * innerH * 0.7;

    let bars = "";
    snowfall_sum.forEach((s, i) => {
      const x = xCenter(i) - barW / 2;
      const y = ySnow(s);
      const h = PAD_Y + innerH - y;
      bars += `<rect x="${x.toFixed(2)}" y="${y.toFixed(2)}" width="${barW.toFixed(2)}" height="${Math.max(0, h).toFixed(2)}" rx="4" fill="url(#snowGrad)" />`;
      if (s > 0) {
        bars += `<text x="${xCenter(i)}" y="${(y - 6).toFixed(2)}" text-anchor="middle" fill="currentColor" font-size="10" opacity="0.8">${s.toFixed(1)}″</text>`;
      }
    });

    const hiPoints = temperature_2m_max
      .map((t, i) => `${xCenter(i).toFixed(2)},${yTemp(t).toFixed(2)}`)
      .join(" ");
    const loPoints = temperature_2m_min
      .map((t, i) => `${xCenter(i).toFixed(2)},${yTemp(t).toFixed(2)}`)
      .join(" ");

    // Filled band between high and low
    const band =
      temperature_2m_max
        .map((t, i) => `${xCenter(i).toFixed(2)},${yTemp(t).toFixed(2)}`)
        .join(" ") +
      " " +
      temperature_2m_min
        .slice()
        .reverse()
        .map((t, i) => {
          const idx = temperature_2m_min.length - 1 - i;
          return `${xCenter(idx).toFixed(2)},${yTemp(t).toFixed(2)}`;
        })
        .join(" ");

    const zeroLineY = yTemp(0);

    svg.innerHTML = `
      <defs>
        <linearGradient id="snowGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--color-glacier-300)" stop-opacity="0.95" />
          <stop offset="100%" stop-color="var(--color-glacier-600)" stop-opacity="0.4" />
        </linearGradient>
        <linearGradient id="tempBand" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--color-sunset-400)" stop-opacity="0.25" />
          <stop offset="100%" stop-color="var(--color-sunset-500)" stop-opacity="0.05" />
        </linearGradient>
      </defs>
      ${bars}
      ${
        zeroLineY > PAD_Y && zeroLineY < PAD_Y + innerH
          ? `<line x1="${PAD_X}" x2="${W - PAD_X}" y1="${zeroLineY}" y2="${zeroLineY}" stroke="currentColor" stroke-dasharray="3 4" opacity="0.25" />
             <text x="${W - PAD_X + 2}" y="${zeroLineY + 3}" font-size="10" fill="currentColor" opacity="0.5">0°C</text>`
          : ""
      }
      <polygon points="${band}" fill="url(#tempBand)" />
      <polyline points="${hiPoints}" fill="none" stroke="var(--color-sunset-400)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
      <polyline points="${loPoints}" fill="none" stroke="var(--color-sunset-600)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" stroke-dasharray="0" opacity="0.75" />
    `;

    labels.innerHTML = time
      .map(
        (t, i) =>
          `<div><div class="opacity-70">${dayShort(t)}</div><div class="text-[var(--fg)] font-medium">${Math.round(temperature_2m_max[i]!)}°/${Math.round(temperature_2m_min[i]!)}°</div></div>`
      )
      .join("");
  }

  async function load() {
    const end = new Date();
    const start = new Date(end.getTime() - 6 * 86400000);
    const fmt = (d: Date) => d.toISOString().slice(0, 10);
    const url =
      "https://api.open-meteo.com/v1/forecast?latitude=50.1163&longitude=-122.9574" +
      "&daily=snowfall_sum,temperature_2m_max,temperature_2m_min" +
      `&start_date=${fmt(start)}&end_date=${fmt(end)}` +
      "&timezone=auto&temperature_unit=celsius&precipitation_unit=inch";
    const res = await fetch(url);
    if (!res.ok) throw new Error("chart fetch failed");
    const data = (await res.json()) as Data;
    renderChart(data);
  }

  load().catch((err) => {
    console.warn("[snow chart]", err);
    document.getElementById("snow-chart-empty")?.classList.remove("hidden");
  });
</script>
