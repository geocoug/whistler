  <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row gap-4 items-center justify-between text-sm">
    <div class="muted">
      &copy; {year} Whistler.live &middot; Not affiliated with Whistler Blackcomb or Vail Resorts.
    </div>
    <ul class="flex items-center gap-4 muted">
      <li>
        <a class="hover:text-[var(--fg)]" href="https://www.whistlerblackcomb.com/" target="_blank" rel="noopener">Whistler Blackcomb</a>
      </li>
      <li>
        <a class="hover:text-[var(--fg)]" href="https://avalanche.ca/" target="_blank" rel="noopener">Avalanche Canada</a>
      </li>
      <li>
        <a class="hover:text-[var(--fg)]" href="https://github.com/geocoug/whistler" target="_blank" rel="noopener">Source</a>
      </li>
    </ul>
  </div>
</footer>
