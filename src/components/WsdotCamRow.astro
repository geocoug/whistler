---
import { wsdotBorderCams } from "../data/borderCams";
---

<section class="space-y-3">
  <div class="flex items-end justify-between gap-3">
    <h2 class="font-display text-xl font-semibold">US Border Cams <span class="muted text-sm font-sans font-normal">· WSDOT</span></h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {
      wsdotBorderCams.map((cam) => (
        <article class="cam-tile" data-wsdot-cam>
          <header>
            <div class="min-w-0">
              <div class="truncate">{cam.fallbackTitle}</div>
              <div class="text-[11px] font-normal muted font-sans">WSDOT ID {cam.cameraId}</div>
            </div>
            <button
              class="star-btn"
              type="button"
              data-lightbox
              data-lightbox-src={cam.imageUrl}
              data-lightbox-title={cam.fallbackTitle}
              aria-label={`Expand ${cam.fallbackTitle}`}
              title="Expand"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
              </svg>
            </button>
          </header>
          <div class="media">
            <img
              src={`${cam.imageUrl}?t=0`}
              data-src={cam.imageUrl}
              alt={cam.fallbackTitle}
              referrerpolicy="no-referrer"
              loading="lazy"
            />
          </div>
        </article>
      ))
    }
  </div>
</section>

<script>
  // Auto-refresh WSDOT cam images every 60s
  document.querySelectorAll<HTMLElement>("[data-wsdot-cam]").forEach((tile) => {
    setInterval(() => {
      const img = tile.querySelector<HTMLImageElement>("img");
      if (!img) return;
      const base = img.dataset.src ?? img.src.split("?")[0];
      img.src = `${base}?t=${Date.now()}`;
    }, 60_000);
  });
</script>
